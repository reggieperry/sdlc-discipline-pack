{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // empty' | { read -r f; case \"$f\" in *.py) uv run ruff format \"$f\" && uv run ruff check --fix \"$f\" ;; esac; } 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(**)",
      "Bash(uv run pytest *)",
      "Bash(uv run ruff *)",
      "Bash(uv run mypy *)",
      "Bash(uv run lint-imports *)",
      "Bash(uv sync *)",
      "Bash(uv add *)",
      "Bash(uv lock *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git status *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git worktree *)",
      "Bash(git stash *)",
      "Bash(git rm *)",
      "Bash(git rev-parse *)",
      "Bash(git merge-base *)",
      "Bash(git show *)",
      "Bash(git show-ref *)",
      "Bash(git remote *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(gh repo *)",
      "Bash(gh run *)",
      "Bash(bd *)",
      "Bash(gc *)",
      "Bash(jq *)",
      "Bash(python3 *)",
      "Bash(bash *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(diff *)",
      "Bash(mkdir *)"
    ],
    "deny": [
      "Bash(git push -f *)",
      "Bash(git push --force origin *)",
      "Bash(git push --force HEAD*)",
      "Bash(git reset --hard origin/main)",
      "Bash(git reset --hard main)",
      "Bash(git reset --hard origin/master)",
      "Bash(git reset --hard master)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /*)"
    ]
  },
  "awaySummaryEnabled": false
}
